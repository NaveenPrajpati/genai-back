# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# --- Runtime / auth ---
APP_ENV=development                  # set to "production" in prod (enforces JWT_SECRET)
JWT_SECRET=                          # REQUIRED in production: a long random secret
                                     # (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`)

# --- LLM ---
OPENAI_API_KEY=sk-...

# --- Vector DB (RAG) ---
PINECONE_KEY=...

# --- Supabase (chats, messages, meal plans/slots, todos, memory) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=...

# --- MongoDB (users, roadmaps, digests, triggers, approvals) ---
DATABASE_URL=postgresql://...        # Postgres for the LangGraph checkpointer
MONGODB_URI=mongodb+srv://...

# --- Redis (semantic cache) ---
REDIS_URL=redis://localhost:6379

# --- Tools ---
TAVILY_API_KEY=...                   # web search (degrades gracefully if unset)
JINA_API_KEY=...                     # reranker
EDAMAM_APP_ID=...                    # meal-planner nutrition lookup
EDAMAM_APP_KEY=...

# --- Observability: LangSmith tracing (opt-in) ---
LANGSMITH_TRACING=false              # set true to send traces
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=aiengineer-agents

# --- Fine-tuning capture (opt-in, off by default) ---
LLM_CAPTURE=0
LLM_CAPTURE_PATH=captures/llm_calls.jsonl
